# ⚙️ متغيرات البيئة لـ KnightBot MD
# انسخ هذا الملف إلى .env واملأ القيم الفعلية
# cp .env.example .env

# ─── معلومات البوت الأساسية ───
BOT_NAME=⚔️ KnightBot MD
BOT_PREFIX=.
OWNER_NUMBER=201044626335
OWNER_NAME=ادهم خالد

# ─── مفاتيح الذكاء الاصطناعي (اختياري - املأ ما تريد تفعيله) ───
# احصل عليه من: https://aistudio.google.com/
GEMINI_API_KEY=

# احصل عليه من: https://openrouter.ai/
OPENROUTER_API_KEY=

# مفاتيح بديلة (اختياري)
LOLHUMAN_API_KEY=
BETABOTZ_API_KEY=

# ─── إعدادات إضافية (اختياري) ───
# مستوى السجل (debug, info, warn, error)
LOG_LEVEL=info

# أقصى مدة فيديو بالثواني (10 دقائق افتراضياً)
MAX_VIDEO_DURATION=600

# أقصى مدة صوت بالثواني (20 دقيقة افتراضياً)
MAX_AUDIO_DURATION=1200
