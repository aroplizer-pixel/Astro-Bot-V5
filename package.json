{
  "name": "knightbot-md",
  "version": "2.0.0",
  "description": "KnightBot MD v2.0 - Next-Gen WhatsApp Bot by Antigravity",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "migrate": "node -e \"import('./lib/migrate.js').then(m => m.runMigrationIfNeeded())\"",
    "docker:build": "docker build -t knightbot-md .",
    "docker:up": "docker compose up -d",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@whiskeysockets/baileys": "^6.7.9",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.3.0",
    "chalk": "^5.3.0",
    "ffmpeg-static": "^5.3.0",
    "file-type": "^19.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "mime-types": "^2.1.35",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.5",
    "ws": "^8.21.0",
    "youtube-dl-exec": "^3.1.8",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
